NODE_ENV="production"
APP_ENV="staging"
PORT="3000"
TZ="America/Sao_Paulo"
DATABASE_CONNECTION_LIMIT="1"
DATABASE_URL="postgresql://postgres.STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

SUPABASE_URL="https://STAGING_REF.supabase.co"
