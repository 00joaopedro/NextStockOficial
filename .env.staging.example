SUPABASE_STORAGE_BUCKET_PRODUCT_IMAGES="staging-product-images"
SUPABASE_STORAGE_BUCKET_EXPENSE_FILES="staging-expense-files"
SUPABASE_STORAGE_BUCKET_SALE_DOCUMENTS="staging-sale-documents"
SUPABASE_STORAGE_BUCKET_FISCAL_CERTIFICATES="staging-fiscal-certificates"
SUPABASE_STORAGE_SIGNED_URLS="true"
CERT_ENCRYPTION_KEY=""
