PUBLIC_APP_URL="https://staging.example.com"
NEXTSTOCK_PUBLIC_URL="https://staging.example.com"
SUPABASE_PASSWORD_REDIRECT_URL="https://staging.example.com/login.html"
CORS_ALLOWED_ORIGINS="https://staging.example.com"
PRODUCTION_APP_HOST="app.example.com"
CSP_ENFORCE="false"

BILLING_EXTERNAL_REFERENCE_SECRET=""
BILLING_ENFORCEMENT_ENABLED="false"
BILLING_DEFAULT_PROVIDER="MERCADO_PAGO"
BILLING_MODE="sandbox"
BILLING_CHECKOUT_ENABLED="false"
BILLING_WEBHOOK_ENABLED="false"
