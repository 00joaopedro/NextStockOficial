{
  "name": "nest-test",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "start:prod": "node dist/src/main.js",
    "start:railway": "npm run start:prod",
    "db:migrate": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate deploy",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"src/{audit,sessions,observability,privacy}/**/*.ts\" \"src/storage/{stored-files.service,upload-quota.service,file-scanner.interface}.ts\" \"src/config/environment.ts\" \"src/auth/{auth.controller,roles.guard,jwt-auth.guard}.ts\" \"src/security/public-rate-limit.guard.ts\" \"src/tenancy/branch-context.guard.ts\" \"src/system/system.service.ts\" \"src/system/dto/system-context-response.dto.ts\" \"src/system/interfaces/system-context.interface.ts\" \"test/{security,helpers,factories}/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:security": "jest --config ./test/jest-security.json --runInBand",
    "security:static": "node scripts/security/static-check.mjs",
    "audit:ci": "npm audit --omit=dev --audit-level=critical",
    "test:ci": "npm run lint:check && npm run build && npm run build:frontend && npm test -- --runInBand",
    "migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "railway:migrate": "ts-node scripts/migrations/validate-target.ts && prisma migrate deploy",
    "sessions:cleanup": "ts-node scripts/maintenance/session-cleanup.ts",
    "audit:retention-report": "ts-node scripts/maintenance/audit-retention-report.ts",
    "storage:orphan-report": "ts-node scripts/maintenance/storage-orphan-report.ts",
    "uploads:quota-report": "ts-node scripts/maintenance/upload-quota-report.ts",
    "privacy:report-pii": "ts-node scripts/privacy/report-pii.ts",
    "privacy:report-retention": "ts-node scripts/privacy/report-retention.ts",
    "security:smoke": "ts-node scripts/maintenance/security-smoke.ts",
    "backup:verify": "ts-node scripts/backup/verify-backup.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.98.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "joi": "^18.2.3",
    "jwks-rsa": "^4.0.1",
    "node-forge": "^1.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.2",
    "@fastify/compress": "^8.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/platform-fastify": "^11.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
