# Railway/runtime: Supabase Transaction Pooler (port 6543).
NODE_ENV="development"
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Prisma CLI/migrations: prefer Supabase Session Pooler (port 5432).
# If unavailable, keep migrations manual and use the SQL Editor only as plan B.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
CORS_ALLOWED_ORIGINS="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"
CSP_ENFORCE="false"

JWT_SECRET=""

DEV_SUPER_ADMIN_EMAILS=""
DEV_SUPER_ADMIN_USER_IDS=""
DEV_RAILWAY_MONTHLY_COST_CENTS=""
DEV_SUPABASE_MONTHLY_COST_CENTS=""

RAILWAY_API_TOKEN=""
RAILWAY_PROJECT_ID=""
RAILWAY_ENVIRONMENT_ID=""
RAILWAY_SERVICE_ID=""

SUPABASE_PROJECT_REF=""
SUPABASE_ACCESS_TOKEN=""

SUPABASE_STORAGE_BUCKET_PET_PHOTOS="pet-photos"
PET_PHOTO_MAX_SIZE_MB="5"
SUPABASE_STORAGE_BUCKET_PRODUCT_IMAGES="product-images"
PRODUCT_IMAGE_MAX_SIZE_MB="5"
SUPABASE_STORAGE_BUCKET_EXPENSE_FILES="expense-files"
EXPENSE_FILE_MAX_SIZE_MB="10"
SUPABASE_STORAGE_BUCKET_SALE_DOCUMENTS="sale-documents"
SUPABASE_STORAGE_SIGNED_URLS="true"
IMAGE_MAX_INPUT_PIXELS="40000000"

# Development-only seed. Both values are required; production never seeds demo data.
NEXTSTOCK_DEMO_TENANT_ID=""
NEXTSTOCK_DEMO_BRANCH_ID=""

# SaaS billing. Keep enforcement disabled until migration, seed and backfill are verified.
BILLING_DEFAULT_PROVIDER="mercado_pago"
BILLING_ENFORCEMENT_ENABLED="false"
BILLING_CHECKOUT_ENABLED="true"
BILLING_WEBHOOK_ENABLED="false"
BILLING_EXTERNAL_REFERENCE_SECRET=""
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
MERCADO_PAGO_COLLECTOR_ID=""
MERCADO_PAGO_MODE="production"
MERCADO_PAGO_WEBHOOK_TOLERANCE_SECONDS="600"

# A1 certificate encryption and private storage.
CERT_ENCRYPTION_KEY=""
CERT_ENCRYPTION_KEY_VERSION="v1"
SUPABASE_STORAGE_BUCKET_FISCAL_CERTIFICATES="fiscal-certificates"
CERTIFICATE_MAX_SIZE_MB="5"
