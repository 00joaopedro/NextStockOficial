# Copy values into protected Railway variables. Never commit a populated .env.
NODE_ENV="production"
APP_ENV="production"
PORT="3000"
TZ="America/Sao_Paulo"

# PostgreSQL / Prisma / Supabase
DATABASE_URL="postgresql://postgres.PRODUCTION_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
# Required for migrations and administrative scripts. Must NOT use the Supabase
# transaction pooler on port 6543. Prefer the Supabase direct connection or the
# Session Pooler on port 5432 when direct IPv6 is not reachable from Railway.
DIRECT_URL="postgresql://postgres.PRODUCTION_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
# Optional override for scripts/migrations when DIRECT_URL is reserved for local use.
ADMIN_DATABASE_URL=""
DATABASE_CONNECTION_LIMIT="1"
SUPABASE_URL="https://PRODUCTION_REF.supabase.co"
SUPABASE_PROJECT_REF="PRODUCTION_REF"
PRODUCTION_SUPABASE_PROJECT_REF="PRODUCTION_REF"
STAGING_SUPABASE_PROJECT_REF="STAGING_REF"
SUPABASE_ANON_KEY=""
# Alternative to SUPABASE_ANON_KEY; configure one of the two.
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Required only for legacy HS256 projects; ES256 uses Supabase JWKS.
SUPABASE_JWT_SECRET=""

# Public URLs / CORS
CORS_ALLOWED_ORIGINS="https://app.example.com"
PUBLIC_APP_URL="https://app.example.com"
NEXTSTOCK_PUBLIC_URL="https://app.example.com"
PRODUCTION_APP_HOST="app.example.com"
SUPABASE_PASSWORD_REDIRECT_URL="https://app.example.com/login.html"
CSP_ENFORCE="false"
COMPRESSION_THRESHOLD_BYTES="1024"

# Security / sessions / audit
AUDIT_HASH_SECRET=""
SESSION_HASH_SECRET=""
SESSION_ENFORCEMENT_ENABLED="false"
SESSION_RETENTION_DAYS="120"
JWT_DIAGNOSTIC_LOGS="false"

# Billing. Keep both entry points explicitly false until their secrets are ready.
BILLING_ENFORCEMENT_ENABLED="false"
BILLING_CHECKOUT_ENABLED="false"
BILLING_WEBHOOK_ENABLED="false"
BILLING_DEFAULT_PROVIDER="mercado_pago"
BILLING_MODE="production"
BILLING_EXTERNAL_REFERENCE_SECRET=""
MERCADO_PAGO_MODE="production"
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
MERCADO_PAGO_COLLECTOR_ID=""
MERCADO_PAGO_PLAN_ID_OURO=""
MERCADO_PAGO_PLAN_ID_ESMERALDA=""
MERCADO_PAGO_PLAN_ID_DIAMANTE=""
MERCADO_PAGO_WEBHOOK_TOLERANCE_SECONDS="600"

# Storage / uploads
SUPABASE_STORAGE_BUCKET_PRODUCT_IMAGES="product-images"
SUPABASE_STORAGE_BUCKET_PET_PHOTOS="pet-photos"
SUPABASE_STORAGE_BUCKET_EXPENSE_FILES="expense-files"
SUPABASE_STORAGE_BUCKET_SALE_DOCUMENTS="sale-documents"
SUPABASE_STORAGE_BUCKET_FISCAL_CERTIFICATES="fiscal-certificates"
SUPABASE_STORAGE_SIGNED_URLS="true"
PRODUCT_IMAGE_MAX_SIZE_MB="5"
PET_PHOTO_MAX_SIZE_MB="5"
EXPENSE_FILE_MAX_SIZE_MB="10"
CERTIFICATE_MAX_SIZE_MB="5"
IMAGE_MAX_INPUT_PIXELS="40000000"
UPLOAD_ENABLE_QUOTAS="false"
UPLOAD_DAILY_BYTES_PER_TENANT="524288000"
UPLOAD_DAILY_FILES_PER_TENANT="200"
UPLOAD_DAILY_BYTES_PER_USER="104857600"
UPLOAD_STORAGE_BYTES_PER_TENANT="5368709120"
UPLOAD_SIGNED_URL_TTL_SECONDS="600"

# Fiscal A1: required at bootstrap because the fiscal module is active.
CERT_ENCRYPTION_KEY=""
CERT_ENCRYPTION_KEY_VERSION="v1"

# Optional observability and Dev metrics
AUDIT_LOG_ENVIRONMENT="production"
SENTRY_ENVIRONMENT="production"
SENTRY_DSN=""
SENTRY_RELEASE=""
DEV_SUPER_ADMIN_EMAILS=""
DEV_SUPER_ADMIN_USER_IDS=""
SUPABASE_ACCESS_TOKEN=""
RAILWAY_API_TOKEN=""
RAILWAY_PROJECT_ID=""
RAILWAY_ENVIRONMENT_ID=""
RAILWAY_SERVICE_ID=""

# Public storefront rollout (use a protected random secret with 32+ characters).
STOREFRONT_PUBLIC_READ_ENABLED="false"
STOREFRONT_ORDERING_ENABLED="false"
STOREFRONT_TOKEN_SECRET=""
