generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id                      String                        @id @db.Uuid
  supabaseUserId          String?                       @unique @map("supabase_user_id") @db.Uuid
  tenantId                String?                       @map("tenant_id") @db.Uuid
  tenant                  Tenant?                       @relation("TenantProfiles", fields: [tenantId], references: [id], onDelete: SetNull)
  email                   String                        @unique
  name                    String
  fullName                String?                       @map("full_name")
  accessNameNormalized    String                        @unique @map("access_name_normalized")
  role                    Role                          @default(Comprador)
  systemType              SystemType?                   @map("system_type")
  allowedSystemTypes      SystemType[]                  @default([]) @map("allowed_system_types")
  isSuperAdmin            Boolean                       @default(false) @map("is_super_admin")
  primaryTenantId         String?                       @map("primary_tenant_id") @db.Uuid
  primaryTenant           Tenant?                       @relation("PrimaryTenantProfiles", fields: [primaryTenantId], references: [id], onDelete: SetNull)
  memberships             TenantMember[]
  devWorkspaces           DevWorkspace[]
  createdAgendaPets       AgendaPet[]                   @relation("AgendaPetCreatedBy")
  updatedAgendaPets       AgendaPet[]                   @relation("AgendaPetUpdatedBy")
  canceledAgendaPets      AgendaPet[]                   @relation("AgendaPetCanceledBy")
  createdOrders           Order[]                       @relation("OrderCreatedBy")
  updatedOrders           Order[]                       @relation("OrderUpdatedBy")
  employee                Employee?                     @relation("EmployeeProfile")
  createdEmployees        Employee[]                    @relation("EmployeeCreatedBy")
  updatedEmployees        Employee[]                    @relation("EmployeeUpdatedBy")
  createdSuppliers        Supplier[]                    @relation("SupplierCreatedBy")
  updatedSuppliers        Supplier[]                    @relation("SupplierUpdatedBy")
  createdExpenses         Expense[]                     @relation("ExpenseCreatedBy")
  updatedExpenses         Expense[]                     @relation("ExpenseUpdatedBy")
  sales                   Sale[]                        @relation("SaleSeller")
  canceledSales           Sale[]                        @relation("SaleCanceledBy")
  createdFiscalDocuments  SaleDocument[]                @relation("SaleDocumentCreatedBy")
  updatedFiscalDocuments  SaleDocument[]                @relation("SaleDocumentUpdatedBy")
  fiscalEvents            FiscalDocumentEvent[]         @relation("FiscalEventCreatedBy")
  fiscalProductionsEnabled CompanyFiscalConfig[]         @relation("FiscalProductionEnabledBy")
  createdPaymentMachines  PaymentMachine[]              @relation("PaymentMachineCreatedBy")
  updatedPaymentMachines  PaymentMachine[]              @relation("PaymentMachineUpdatedBy")
  createdPartners         Partner[]                     @relation("PartnerCreatedBy")
  updatedPartners         Partner[]                     @relation("PartnerUpdatedBy")
  referredProfiles        PartnerReferral[]             @relation("PartnerReferredProfile")
  seenPartnerReferrals    PartnerReferral[]             @relation("PartnerReferralSeenBy")
  partnerLinkEvents       PartnerLinkEvent[]            @relation("PartnerLinkEventActor")
  partnerPaymentChanges   PartnerReferralPaymentEvent[] @relation("PartnerPaymentChangedBy")
  partnerSeenChanges      PartnerReferralSeenEvent[]    @relation("PartnerSeenChangedBy")
  createdBillingCheckouts CheckoutSession[]             @relation("BillingCheckoutCreatedBy")
  billingEvents           BillingEvent[]                @relation("BillingEventActor")
  sessions                UserSession[]
  ownedStoredFiles        StoredFile[]                   @relation("StoredFileOwner")
  createdAt               DateTime                      @default(now()) @map("created_at")
  updatedAt               DateTime                      @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([primaryTenantId])
  @@map("profiles")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  profileId        String    @map("profile_id") @db.Uuid
  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tenantId         String?   @map("tenant_id") @db.Uuid
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  tokenIdHash      String    @unique @map("token_id_hash")
  jwtSubject       String?   @map("jwt_subject")
  expiresAt        DateTime  @map("expires_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  revokedAt        DateTime? @map("revoked_at")
  revokedReason    String?   @map("revoked_reason")
  ipHash           String?   @map("ip_hash")
  userAgentHash    String?   @map("user_agent_hash")
  deviceLabel      String?   @map("device_label")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([profileId, createdAt])
  @@index([profileId, revokedAt])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("user_sessions")
}

model StoredFile {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branchId        String?              @map("branch_id") @db.Uuid
  branch          Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  ownerProfileId  String?              @map("owner_profile_id") @db.Uuid
  ownerProfile    UserProfile?         @relation("StoredFileOwner", fields: [ownerProfileId], references: [id], onDelete: SetNull)
  module          String
  targetType      String?              @map("target_type")
  targetId        String?              @map("target_id")
  bucket          String
  storagePath     String               @map("storage_path")
  originalName    String?              @map("original_name")
  mimeType        String               @map("mime_type")
  extension       String?
  sizeBytes       BigInt               @map("size_bytes")
  sha256          String?
  visibility      StoredFileVisibility @default(SIGNED_ONLY)
  scanStatus      StoredFileScanStatus @default(NOT_REQUIRED) @map("scan_status")
  status          StoredFileStatus     @default(ACTIVE)
  uploadedAt      DateTime             @default(now()) @map("uploaded_at")
  deletedAt       DateTime?            @map("deleted_at")
  lastAccessedAt  DateTime?            @map("last_accessed_at")
  metadata        Json?

  @@index([tenantId, module, uploadedAt])
  @@index([tenantId, status])
  @@index([targetType, targetId])
  @@index([sha256])
  @@index([ownerProfileId, uploadedAt])
  @@unique([bucket, storagePath])
  @@map("stored_files")
}

model SecurityAuditEvent {
  id             String           @id @default(uuid()) @db.Uuid
  eventType      String           @map("event_type")
  severity       AuditSeverity
  actorProfileId String?          @map("actor_profile_id") @db.Uuid
  actorRole      String?          @map("actor_role")
  tenantId       String?          @map("tenant_id") @db.Uuid
  branchId       String?          @map("branch_id") @db.Uuid
  contextKind    AuditContextKind @default(NORMAL) @map("context_kind")
  targetType     String?          @map("target_type")
  targetId       String?          @map("target_id")
  action         String
  outcome        AuditOutcome
  reasonCode     String?          @map("reason_code")
  requestId      String?          @map("request_id")
  ipHash         String?          @map("ip_hash")
  userAgentHash  String?          @map("user_agent_hash")
  metadata       Json?
  beforeState    Json?            @map("before_state")
  afterState     Json?            @map("after_state")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([actorProfileId, createdAt])
  @@index([eventType, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([outcome, severity, createdAt])
  @@index([requestId])
  @@map("security_audit_events")
}

model DevWorkspace {
  id                 String      @id @default(uuid()) @db.Uuid
  devUserId          String      @map("dev_user_id") @db.Uuid
  devUser            UserProfile @relation(fields: [devUserId], references: [id], onDelete: Cascade)
  systemType         SystemType  @map("system_type")
  tenantId           String      @map("tenant_id") @db.Uuid
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId           String      @map("branch_id") @db.Uuid
  branch             Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isDefaultWorkspace Boolean     @default(true) @map("is_default_workspace")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@unique([devUserId, systemType])
  @@index([tenantId])
  @@index([branchId])
  @@map("dev_workspaces")
}

model Tenant {
  id               String                @id @default(uuid()) @db.Uuid
  name             String
  slug             String                @unique
  cnpj             String?
  contactEmail     String?               @map("contact_email")
  contactPhone     String?               @map("contact_phone")
  systemType       SystemType            @default(padrao) @map("system_type")
  mode             SystemMode            @default(visualizacao)
  currentPlanId    String?               @map("current_plan_id") @db.Uuid
  currentPlan      Plan?                 @relation("CurrentPlanTenants", fields: [currentPlanId], references: [id], onDelete: SetNull)
  subscriptions    Subscription[]
  branches         Branch[]
  members          TenantMember[]
  primaryProfiles  UserProfile[]         @relation("PrimaryTenantProfiles")
  profiles         UserProfile[]         @relation("TenantProfiles")
  agendaPets       AgendaPet[]
  petClients       PetClient[]
  pets             Pet[]
  petPhotos        PetPhoto[]
  products         Product[]
  orders           Order[]
  employees        Employee[]
  suppliers        Supplier[]
  expenses         Expense[]
  expenseFiles     ExpenseFile[]
  sales            Sale[]
  saleDocuments    SaleDocument[]
  fiscalConfigs    CompanyFiscalConfig[]
  fiscalSequences  FiscalSequence[]
  paymentMachines  PaymentMachine[]
  devWorkspaces    DevWorkspace[]
  partnerReferrals PartnerReferral[]
  checkoutSessions CheckoutSession[]
  billingPayments  BillingPayment[]
  billingEvents    BillingEvent[]
  userSessions     UserSession[]
  storedFiles      StoredFile[]
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@index([currentPlanId])
  @@map("tenants")
}

model Plan {
  id               String               @id @default(uuid()) @db.Uuid
  name             String
  slug             String               @unique
  priceCents       Int                  @map("price_cents")
  currency         String               @default("BRL")
  interval         PlanInterval         @default(MONTHLY)
  intervalCount    Int                  @default(1) @map("interval_count")
  features         Json?
  sortOrder        Int                  @default(0) @map("sort_order")
  description      String?
  isActive         Boolean              @default(true) @map("is_active")
  deletedAt        DateTime?            @map("deleted_at")
  tenants          Tenant[]             @relation("CurrentPlanTenants")
  subscriptions    Subscription[]
  gatewayMappings  GatewayPlanMapping[]
  checkoutSessions CheckoutSession[]
  billingPayments  BillingPayment[]
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("plans")
}

model PaymentMachine {
  /// Payment machines are branch-wide. Legacy rows without branchId are not exposed.
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId          String?         @map("branch_id") @db.Uuid
  branch            Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name              String
  provider          PaymentProvider
  model             String
  feePercent        Decimal         @map("fee_percent") @db.Decimal(5, 2)
  status            MachineStatus   @default(ativa)
  externalProvider  String?         @map("external_provider")
  externalReference String?         @map("external_reference")
  createdById       String?         @map("created_by_id") @db.Uuid
  updatedById       String?         @map("updated_by_id") @db.Uuid
  deletedAt         DateTime?       @map("deleted_at")
  sales             Sale[]          @relation("SalePrimaryPaymentMachine")
  salePayments      SalePayment[]   @relation("SalePaymentMachine")
  createdBy         UserProfile?    @relation("PaymentMachineCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         UserProfile?    @relation("PaymentMachineUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status])
  @@index([createdById])
  @@index([updatedById])
  @@map("payment_machines")
}

model Subscription {
  id                     String                  @id @default(uuid()) @db.Uuid
  tenantId               String                  @map("tenant_id") @db.Uuid
  planId                 String?                 @map("plan_id") @db.Uuid
  status                 SubscriptionStatus      @default(pending)
  trialStartedAt         DateTime?               @map("trial_started_at")
  trialEndsAt            DateTime?               @map("trial_ends_at")
  currentPeriodStartedAt DateTime?               @map("current_period_start")
  currentPeriodEndsAt    DateTime?               @map("current_period_end")
  graceEndsAt            DateTime?               @map("grace_ends_at")
  gatewayProvider        PaymentGatewayProvider? @map("gateway_provider")
  gatewaySubscriptionId  String?                 @map("provider_subscription_id")
  lastPaymentAt          DateTime?               @map("last_payment_at")
  cancelAtPeriodEnd      Boolean                 @default(false) @map("cancel_at_period_end")
  version                Int                     @default(1)
  canceledAt             DateTime?               @map("canceled_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  tenant               Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan?                         @relation(fields: [planId], references: [id], onDelete: Restrict)
  partnerPaymentEvents PartnerReferralPaymentEvent[]
  checkoutSessions     CheckoutSession[]
  billingPayments      BillingPayment[]
  billingEvents        BillingEvent[]

  @@index([tenantId, status])
  @@index([tenantId, updatedAt])
  @@index([planId])
  @@index([gatewayProvider, gatewaySubscriptionId])
  @@map("subscriptions")
}

model GatewayPlanMapping {
  id             String                 @id @default(uuid()) @db.Uuid
  planId         String                 @map("plan_id") @db.Uuid
  provider       PaymentGatewayProvider
  gatewayPlanId  String?                @map("gateway_plan_id")
  paymentLinkUrl String?                @map("payment_link_url")
  mode           String                 @default("production")
  isActive       Boolean                @default(true) @map("is_active")
  metadata       Json?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, provider, mode])
  @@index([provider, gatewayPlanId, mode])
  @@map("gateway_plan_mappings")
}

model CheckoutSession {
  id                  String                 @id @default(uuid()) @db.Uuid
  tenantId            String                 @map("tenant_id") @db.Uuid
  planId              String                 @map("plan_id") @db.Uuid
  subscriptionId      String?                @map("subscription_id") @db.Uuid
  provider            PaymentGatewayProvider
  gatewayCheckoutId   String?                @map("gateway_checkout_id")
  checkoutUrl         String                 @map("checkout_url")
  externalReference   String                 @unique @map("external_reference")
  status              CheckoutSessionStatus  @default(OPEN)
  expectedAmountCents Int                    @map("expected_amount_cents")
  currency            String                 @default("BRL")
  expiresAt           DateTime?              @map("expires_at")
  createdById         String?                @map("created_by_id") @db.Uuid
  completedAt         DateTime?              @map("completed_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan          Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription  Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdBy     UserProfile?     @relation("BillingCheckoutCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  payments      BillingPayment[]
  billingEvents BillingEvent[]

  @@index([tenantId, status, createdAt])
  @@index([planId])
  @@index([provider, gatewayCheckoutId])
  @@map("checkout_sessions")
}

model BillingPayment {
  id                String                 @id @default(uuid()) @db.Uuid
  tenantId          String                 @map("tenant_id") @db.Uuid
  subscriptionId    String?                @map("subscription_id") @db.Uuid
  planId            String                 @map("plan_id") @db.Uuid
  checkoutSessionId String?                @map("checkout_session_id") @db.Uuid
  provider          PaymentGatewayProvider
  gatewayPaymentId  String?                @map("gateway_payment_id")
  externalReference String                 @map("external_reference")
  status            BillingPaymentStatus   @default(PENDING)
  amountCents       Int                    @map("amount_cents")
  currency          String                 @default("BRL")
  rawGatewayStatus  String?                @map("raw_gateway_status")
  paidAt            DateTime?              @map("paid_at")
  refundedAt        DateTime?              @map("refunded_at")
  metadata          Json?
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  subscription    Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan            Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  billingEvents   BillingEvent[]

  @@index([tenantId, status, createdAt])
  @@index([checkoutSessionId])
  @@index([externalReference])
  @@index([provider, gatewayPaymentId])
  @@map("billing_payments")
}

model GatewayWebhookEvent {
  id               String                         @id @default(uuid()) @db.Uuid
  provider         PaymentGatewayProvider
  gatewayEventId   String?                        @map("gateway_event_id")
  resourceId       String?                        @map("resource_id")
  eventType        String?                        @map("event_type")
  requestId        String?                        @map("request_id")
  signatureValid   Boolean                        @default(false) @map("signature_valid")
  payloadHash      String                         @map("payload_hash")
  rawPayload       Json?                          @map("raw_payload")
  processingStatus GatewayWebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  attemptCount     Int                            @default(0) @map("attempt_count")
  processedAt      DateTime?                      @map("processed_at")
  processingError  String?                        @map("processing_error")
  createdAt        DateTime                       @default(now()) @map("created_at")
  updatedAt        DateTime                       @updatedAt @map("updated_at")

  @@index([payloadHash])
  @@index([provider, gatewayEventId])
  @@index([processingStatus, createdAt])
  @@map("gateway_webhook_events")
}

model BillingEvent {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String?          @map("tenant_id") @db.Uuid
  subscriptionId    String?          @map("subscription_id") @db.Uuid
  paymentId         String?          @map("payment_id") @db.Uuid
  checkoutSessionId String?          @map("checkout_session_id") @db.Uuid
  type              BillingEventType
  previousState     Json?            @map("previous_state")
  nextState         Json?            @map("next_state")
  actorProfileId    String?          @map("actor_profile_id") @db.Uuid
  source            String
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subscription    Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment         BillingPayment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  actorProfile    UserProfile?     @relation("BillingEventActor", fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
  @@map("billing_events")
}

model Branch {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @map("tenant_id") @db.Uuid
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  slug             String
  isDefault        Boolean               @default(false) @map("is_default")
  isActive         Boolean               @default(true) @map("is_active")
  members          TenantMember[]
  petClients       PetClient[]
  pets             Pet[]
  petPhotos        PetPhoto[]
  agendaPets       AgendaPet[]
  products         Product[]
  orders           Order[]
  employees        Employee[]
  suppliers        Supplier[]
  expenses         Expense[]
  expenseFiles     ExpenseFile[]
  sales            Sale[]
  saleDocuments    SaleDocument[]
  fiscalConfigs    CompanyFiscalConfig[]
  fiscalSequences  FiscalSequence[]
  paymentMachines  PaymentMachine[]
  devWorkspaces    DevWorkspace[]
  partnerReferrals PartnerReferral[]
  storedFiles       StoredFile[]
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("branches")
}

model TenantMember {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userProfileId String      @map("user_profile_id") @db.Uuid
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  branchId      String?     @map("branch_id") @db.Uuid
  branch        Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role          Role        @default(Comprador)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([tenantId, userProfileId])
  @@index([userProfileId])
  @@index([branchId])
  @@map("tenant_members")
}

model AgendaPet {
  id                 String          @id @default(uuid()) @db.Uuid
  cliente            String
  animal             String
  atendente          String
  servico            String
  data               DateTime
  hora               String
  preco              Float
  descricao          String?
  status             AgendaPetStatus @default(scheduled)
  startAt            DateTime?       @map("start_at")
  endAt              DateTime?       @map("end_at")
  notes              String?
  createdById        String?         @map("created_by_id") @db.Uuid
  updatedById        String?         @map("updated_by_id") @db.Uuid
  canceledById       String?         @map("canceled_by_id") @db.Uuid
  canceledAt         DateTime?       @map("canceled_at")
  cancellationReason String?         @map("cancellation_reason")
  deletedAt          DateTime?       @map("deleted_at")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenantId           String          @db.Uuid
  branchId           String?         @map("branch_id") @db.Uuid
  clientId           String?         @map("client_id") @db.Uuid
  petId              String?         @map("pet_id") @db.Uuid
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  client             PetClient?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  pet                Pet?            @relation(fields: [petId], references: [id], onDelete: SetNull)
  createdBy          UserProfile?    @relation("AgendaPetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          UserProfile?    @relation("AgendaPetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  canceledBy         UserProfile?    @relation("AgendaPetCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, startAt])
  @@index([tenantId, branchId, deletedAt, startAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, clientId])
  @@index([tenantId, branchId, petId])
  @@index([tenantId])
  @@index([clientId])
  @@index([petId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("agenda_pets")
}

model PetClient {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  name      String
  phone     String
  email     String?
  document  String?
  address   Json?
  notes     String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  pets         Pet[]
