  averageDeliveryTime String?            @map("average_delivery_time")
  productCategories   String?            @map("product_categories")
  paymentTerms        String?            @map("payment_terms")
  status              SupplierStatus     @default(active)
  notes               String?
  createdById         String?            @map("created_by_id") @db.Uuid
  createdBy           UserProfile?       @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?            @map("updated_by_id") @db.Uuid
  updatedBy           UserProfile?       @relation("SupplierUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  expenses            Expense[]
  deletedAt           DateTime?          @map("deleted_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, legalName])
  @@index([tenantId, branchId, document])
  @@index([deletedAt])
  @@map("suppliers")
}

model Expense {
  id                   String        @id @default(uuid()) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  branchId             String        @map("branch_id") @db.Uuid
  type                 ExpenseType
  status               ExpenseStatus @default(pending)
  totalCents           Int           @map("total_cents")
  date                 DateTime
  employeeName         String        @map("employee_name")
  storeName            String        @map("store_name")
  supplierId           String?       @map("supplier_id") @db.Uuid
  supplierNameSnapshot String?       @map("supplier_name_snapshot")
  notes                String?
  createdById          String?       @map("created_by_id") @db.Uuid
  updatedById          String?       @map("updated_by_id") @db.Uuid
  deletedAt            DateTime?     @map("deleted_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier  Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy UserProfile?  @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy UserProfile?  @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items     ExpenseItem[]
  files     ExpenseFile[]

  @@index([tenantId, branchId, date])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, status, deletedAt, date])
  @@index([tenantId, branchId, type])
  @@index([tenantId, branchId, supplierId])
  @@index([deletedAt])
  @@map("expenses")
}

model ExpenseItem {
  id             String   @id @default(uuid()) @db.Uuid
  expenseId      String   @map("expense_id") @db.Uuid
  productName    String   @map("product_name")
  units          Int
  totalCostCents Int      @map("total_cost_cents")
  productId      String?  @map("product_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  expense Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([expenseId])
  @@index([productId])
  @@map("expense_items")
}

model ExpenseFile {
  id          String          @id @default(uuid()) @db.Uuid
  expenseId   String          @map("expense_id") @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  branchId    String          @map("branch_id") @db.Uuid
  fileName    String          @map("file_name")
  mimeType    String          @map("mime_type")
  fileType    ExpenseFileType @map("file_type")
  fileSize    Int             @map("file_size")
  originalSize Int?           @map("original_size")
  width       Int?
  height      Int?
  storagePath String          @map("storage_path")
  fileUrl     String?         @map("file_url")
  createdAt   DateTime        @default(now()) @map("created_at")
  deletedAt   DateTime?       @map("deleted_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([expenseId, deletedAt, createdAt])
  @@index([tenantId, branchId])
  @@index([deletedAt])
  @@map("expense_files")
}

model ProductImage {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileName      String   @map("file_name")
  fileUrl       String?  @map("file_url")
  storagePath   String?  @map("storage_path")
  mediumUrl     String?  @map("medium_url")
  mediumPath    String?  @map("medium_path")
  thumbnailUrl  String?  @map("thumbnail_url")
  thumbnailPath String?  @map("thumbnail_path")
  mimeType      String?  @map("mime_type")
  size          Int?
  originalSize  Int?     @map("original_size")
  width         Int?
  height        Int?
  thumbnailSize Int?     @map("thumbnail_size")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productId, createdAt])
  @@map("product_images")
}

model UserUsageEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  email         String?
  name          String?
  systemType    String?  @map("system_type")
  branchName    String?  @map("branch_name")
  eventType     String   @map("event_type")
  page          String?
  route         String?
  method        String?
  statusCode    Int?     @map("status_code")
  durationMs    Int?     @map("duration_ms")
  weight        Int      @default(1)
  dbReadCount   Int      @default(0) @map("db_read_count")
  dbWriteCount  Int      @default(0) @map("db_write_count")
  responseBytes Int?     @map("response_bytes")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([systemType])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([eventType, createdAt])
  @@index([systemType, createdAt])
  @@map("user_usage_events")
}

model ResourceUsageSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String
  metricName  String   @map("metric_name")
  value       Decimal  @db.Decimal(18, 6)
  unit        String
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  source      String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([provider, metricName, periodStart, periodEnd])
  @@map("resource_usage_snapshots")
}

model Partner {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String
  phone              String
  bankNumber         String            @map("bank_number")
  referralCode       String            @unique @map("referral_code")
  referralCodeHash   String            @unique @map("referral_code_hash")
  referralCodePrefix String            @map("referral_code_prefix")
  linkStatus         PartnerLinkStatus @default(ACTIVE) @map("link_status")
  systemType         SystemType        @map("system_type")
  expiresAt          DateTime?         @map("expires_at")
  lastUsedAt         DateTime?         @map("last_used_at")
  createdById        String            @map("created_by_id") @db.Uuid
  updatedById        String?           @map("updated_by_id") @db.Uuid
  deletedAt          DateTime?         @map("deleted_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  createdBy  UserProfile        @relation("PartnerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy  UserProfile?       @relation("PartnerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  referrals  PartnerReferral[]
  linkEvents PartnerLinkEvent[]

  @@index([deletedAt, linkStatus])
  @@index([createdById])
  @@index([createdAt])
  @@map("partners")
}

model PartnerReferral {
  id                  String                @id @default(uuid()) @db.Uuid
  partnerId           String                @map("partner_id") @db.Uuid
  referredProfileId   String                @unique @map("referred_profile_id") @db.Uuid
  referredTenantId    String                @map("referred_tenant_id") @db.Uuid
  referredBranchId    String                @map("referred_branch_id") @db.Uuid
  systemType          SystemType            @map("system_type")
  status              PartnerReferralStatus @default(REGISTERED)
  paymentStatus       PartnerPaymentStatus  @default(UNPAID) @map("payment_status")
  seenAt              DateTime?             @map("seen_at")
  seenById            String?               @map("seen_by_id") @db.Uuid
  registeredAt        DateTime              @default(now()) @map("registered_at")
  convertedAt         DateTime?             @map("converted_at")
  attributionMetadata Json?                 @map("attribution_metadata")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  partner         Partner                       @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  referredProfile UserProfile                   @relation("PartnerReferredProfile", fields: [referredProfileId], references: [id], onDelete: Restrict)
  referredTenant  Tenant                        @relation(fields: [referredTenantId], references: [id], onDelete: Restrict)
  referredBranch  Branch                        @relation(fields: [referredBranchId], references: [id], onDelete: Restrict)
  seenBy          UserProfile?                  @relation("PartnerReferralSeenBy", fields: [seenById], references: [id], onDelete: SetNull)
  paymentEvents   PartnerReferralPaymentEvent[]
  seenEvents      PartnerReferralSeenEvent[]

  @@index([partnerId, createdAt])
  @@index([referredTenantId])
  @@index([paymentStatus, createdAt])
  @@index([seenAt])
  @@index([createdAt])
  @@map("partner_referrals")
}

model PartnerLinkEvent {
  id             String               @id @default(uuid()) @db.Uuid
  partnerId      String               @map("partner_id") @db.Uuid
  eventType      PartnerLinkEventType @map("event_type")
  actorProfileId String?              @map("actor_profile_id") @db.Uuid
  ipHash         String?              @map("ip_hash")
  userAgentHash  String?              @map("user_agent_hash")
  metadata       Json?
  createdAt      DateTime             @default(now()) @map("created_at")

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  actorProfile UserProfile? @relation("PartnerLinkEventActor", fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([partnerId, createdAt])
  @@index([createdAt])
  @@map("partner_link_events")
}

model PartnerReferralPaymentEvent {
  id              String               @id @default(uuid()) @db.Uuid
  referralId      String               @map("referral_id") @db.Uuid
  previousStatus  PartnerPaymentStatus @map("previous_status")
  newStatus       PartnerPaymentStatus @map("new_status")
  source          PartnerPaymentSource
  providerEventId String?              @map("provider_event_id")
  subscriptionId  String?              @map("subscription_id") @db.Uuid
  changedById     String?              @map("changed_by_id") @db.Uuid
  reason          String?
  createdAt       DateTime             @default(now()) @map("created_at")

  referral     PartnerReferral @relation(fields: [referralId], references: [id], onDelete: Restrict)
  subscription Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  changedBy    UserProfile?    @relation("PartnerPaymentChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([referralId, createdAt])
  @@index([source, providerEventId])
  @@index([createdAt])
  @@map("partner_referral_payment_events")
}

model PartnerReferralSeenEvent {
  id             String    @id @default(uuid()) @db.Uuid
  referralId     String    @map("referral_id") @db.Uuid
  previousSeenAt DateTime? @map("previous_seen_at")
  newSeenAt      DateTime? @map("new_seen_at")
  changedById    String    @map("changed_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  referral  PartnerReferral @relation(fields: [referralId], references: [id], onDelete: Restrict)
  changedBy UserProfile     @relation("PartnerSeenChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([referralId, createdAt])
  @@index([createdAt])
  @@map("partner_referral_seen_events")
}

