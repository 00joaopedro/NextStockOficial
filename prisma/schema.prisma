generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id                   String         @id @db.Uuid
  supabaseUserId       String?        @unique @map("supabase_user_id") @db.Uuid
  tenantId             String?        @map("tenant_id") @db.Uuid
  tenant               Tenant?        @relation("TenantProfiles", fields: [tenantId], references: [id], onDelete: SetNull)
  email                String         @unique
  name                 String
  fullName             String?        @map("full_name")
  accessNameNormalized String         @unique @map("access_name_normalized")
  role                 Role           @default(Comprador)
  systemType           SystemType?    @map("system_type")
  allowedSystemTypes   SystemType[]   @default([]) @map("allowed_system_types")
  isSuperAdmin         Boolean        @default(false) @map("is_super_admin")
  primaryTenantId      String?        @map("primary_tenant_id") @db.Uuid
  primaryTenant        Tenant?        @relation("PrimaryTenantProfiles", fields: [primaryTenantId], references: [id], onDelete: SetNull)
  memberships          TenantMember[]
  devWorkspaces        DevWorkspace[]
  createdAgendaPets    AgendaPet[]    @relation("AgendaPetCreatedBy")
  updatedAgendaPets    AgendaPet[]    @relation("AgendaPetUpdatedBy")
  canceledAgendaPets   AgendaPet[]    @relation("AgendaPetCanceledBy")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([primaryTenantId])
  @@map("profiles")
}

model DevWorkspace {
  id                 String      @id @default(uuid()) @db.Uuid
  devUserId          String      @map("dev_user_id") @db.Uuid
  devUser            UserProfile @relation(fields: [devUserId], references: [id], onDelete: Cascade)
  systemType         SystemType  @map("system_type")
  tenantId           String      @map("tenant_id") @db.Uuid
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId           String      @map("branch_id") @db.Uuid
  branch             Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isDefaultWorkspace Boolean     @default(true) @map("is_default_workspace")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@unique([devUserId, systemType])
  @@index([tenantId])
  @@index([branchId])
  @@map("dev_workspaces")
}

model Tenant {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  slug            String         @unique
  cnpj            String?
  contactEmail    String?        @map("contact_email")
  contactPhone    String?        @map("contact_phone")
  systemType      SystemType     @default(padrao) @map("system_type")
  mode            SystemMode     @default(visualizacao)
  currentPlanId   String?        @map("current_plan_id") @db.Uuid
  currentPlan     Plan?          @relation("CurrentPlanTenants", fields: [currentPlanId], references: [id], onDelete: SetNull)
  branches        Branch[]
  members         TenantMember[]
  primaryProfiles UserProfile[]  @relation("PrimaryTenantProfiles")
  profiles        UserProfile[]  @relation("TenantProfiles")
  agendaPets      AgendaPet[]
  petClients      PetClient[]
  pets            Pet[]
  petPhotos       PetPhoto[]
  products        Product[]
  paymentMachines PaymentMachine[]
  devWorkspaces    DevWorkspace[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([currentPlanId])
  @@map("tenants")
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  priceCents  Int      @map("price_cents")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  tenants     Tenant[] @relation("CurrentPlanTenants")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model PaymentMachine {
  /// Payment machines are branch-wide. Legacy rows without branchId are not exposed.
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId          String?         @map("branch_id") @db.Uuid
  branch            Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name              String
  provider          PaymentProvider
  model             String
  feePercent        Decimal         @map("fee_percent") @db.Decimal(5, 2)
  status            MachineStatus   @default(ativa)
  externalProvider  String?         @map("external_provider")
  externalReference String?         @map("external_reference")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([tenantId, branchId])
  @@map("payment_machines")
}

model Branch {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  isDefault Boolean        @default(false) @map("is_default")
  isActive  Boolean        @default(true) @map("is_active")
  members   TenantMember[]
  petClients PetClient[]
  pets      Pet[]
  petPhotos PetPhoto[]
  agendaPets AgendaPet[]
  products Product[]
  paymentMachines PaymentMachine[]
  devWorkspaces DevWorkspace[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("branches")
}

model TenantMember {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userProfileId String      @map("user_profile_id") @db.Uuid
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  branchId      String?     @map("branch_id") @db.Uuid
  branch        Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role          Role        @default(Comprador)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([tenantId, userProfileId])
  @@index([userProfileId])
  @@index([branchId])
  @@map("tenant_members")
}

model AgendaPet {
  id                 String           @id @default(uuid()) @db.Uuid
  cliente            String
  animal             String
  atendente          String
  servico            String
  data               DateTime
  hora               String
  preco              Float
  descricao          String?
  status             AgendaPetStatus  @default(scheduled)
  startAt            DateTime?        @map("start_at")
  endAt              DateTime?        @map("end_at")
  notes              String?
  createdById        String?          @map("created_by_id") @db.Uuid
  updatedById        String?          @map("updated_by_id") @db.Uuid
  canceledById       String?          @map("canceled_by_id") @db.Uuid
  canceledAt         DateTime?        @map("canceled_at")
  cancellationReason String?          @map("cancellation_reason")
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenantId           String           @db.Uuid
  branchId           String?          @map("branch_id") @db.Uuid
  clientId           String?          @map("client_id") @db.Uuid
  petId              String?          @map("pet_id") @db.Uuid
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  client             PetClient?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  pet                Pet?             @relation(fields: [petId], references: [id], onDelete: SetNull)
  createdBy          UserProfile?     @relation("AgendaPetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          UserProfile?     @relation("AgendaPetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  canceledBy         UserProfile?     @relation("AgendaPetCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, startAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, clientId])
  @@index([tenantId, branchId, petId])
  @@index([tenantId])
  @@index([clientId])
  @@index([petId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("agenda_pets")
}

model PetClient {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  name      String
  phone     String
  email     String?
  document  String?
  address   Json?
  notes     String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  pets         Pet[]
  appointments AgendaPet[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@index([deletedAt])
  @@map("pet_clients")
}

model Pet {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  branchId        String?   @map("branch_id") @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  name            String
  species         String    @default("dog")
  breed           String?
  birthDate       DateTime? @map("birth_date")
  ageText         String?   @map("age_text")
  weight          String?
  height          String?
  width           String?
  length          String?
  foodPerDay      String?   @map("food_per_day")
  description     String?
  vaccinesTaken   String?   @map("vaccines_taken")
  vaccinesPending String?   @map("vaccines_pending")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  client       PetClient   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  photos       PetPhoto[]
  appointments AgendaPet[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([clientId])
  @@index([tenantId, clientId])
  @@index([deletedAt])
  @@map("pets")
}

model PetPhoto {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  branchId    String?  @map("branch_id") @db.Uuid
  petId       String   @map("pet_id") @db.Uuid
  fileName    String   @map("file_name")
  fileUrl     String?  @map("file_url")
  storagePath String?  @map("storage_path")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([petId])
  @@map("pet_photos")
}

model Product {
  /// Products are branch-wide. Legacy rows without branchId are not exposed.
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         String?        @map("branch_id") @db.Uuid
  branch           Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name             String
  costPriceCents   Int            @map("cost_price_cents")
  profitPercent    Decimal        @map("profit_percent") @db.Decimal(7, 2)
  salePriceCents   Int            @map("sale_price_cents")
  quantity         Int
  brand            String?
  category         String?
  supplier         String?
  sku              String?
  barcode          String?
  description      String?
  weight           String?
  height           String?
  width            String?
  externalLink     String?        @map("external_link")
  clothingSize     String?        @map("clothing_size")
  apparelSize      String?        @map("apparel_size")
  images           ProductImage[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([tenantId, branchId, sku])
  @@unique([tenantId, branchId, barcode])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, category])
  @@map("products")
}

model ProductImage {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileName    String   @map("file_name")
  fileUrl     String?  @map("file_url")
  storagePath String?  @map("storage_path")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model UserUsageEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  email         String?
  name          String?
  systemType    String?  @map("system_type")
  branchName    String?  @map("branch_name")
  eventType     String   @map("event_type")
  page          String?
  route         String?
  method        String?
  statusCode    Int?     @map("status_code")
  durationMs    Int?     @map("duration_ms")
  weight        Int      @default(1)
  dbReadCount   Int      @default(0) @map("db_read_count")
  dbWriteCount  Int      @default(0) @map("db_write_count")
  responseBytes Int?     @map("response_bytes")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([systemType])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([eventType, createdAt])
  @@index([systemType, createdAt])
  @@map("user_usage_events")
}

model ResourceUsageSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String
  metricName  String   @map("metric_name")
  value       Decimal  @db.Decimal(18, 6)
  unit        String
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  source      String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([provider, metricName, periodStart, periodEnd])
  @@map("resource_usage_snapshots")
}

enum Role {
  superAdmin
  Admin
  Vendedor
  Comprador
}

enum SystemType {
  padrao
  petshop
}

enum SystemMode {
  visualizacao
  padrao
  petshop
}

enum AgendaPetStatus {
  scheduled
  confirmed
  in_progress
  completed
  canceled
  no_show
}

enum MachineStatus {
  ativa
  inativa
  manutencao
}

enum PaymentProvider {
  stone
  pagseguro
  mercado_pago
  outro
}
